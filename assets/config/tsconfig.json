{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "lib":              ["ES2020", "DOM"],
    "esModuleInterop":  true,
    "strict":           true,
    "skipLibCheck":     true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir":           "./dist",
    "rootDir":          "./"
  },
  "include": [
    "./contracts",
    "./test",
    "./scripts",
    "./hardhat.config.ts"
  ],
  "exclude": [
    "node_modules",
    "artifacts",
    "cache",
    "dist",
    "coverage",
    "types"
  ]
}
